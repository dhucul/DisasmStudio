<Window x:Class="DisasmStudio.Wpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ctl="clr-namespace:DisasmStudio.Wpf.Controls"
        Title="DisasmStudio" Height="820" Width="1320"
        Icon="DisasmStudio.ico"
        FontFamily="Segoe UI" FontSize="12.5">
    <DockPanel>
        <!-- Toolbar -->
        <Border DockPanel.Dock="Top" Background="{StaticResource Surface}"
                BorderBrush="{StaticResource Outline}" BorderThickness="0,0,0,1" Padding="8,6">
            <!-- WrapPanel so a narrow window flows buttons onto another row instead of clipping them. -->
            <WrapPanel>
                <Button x:Name="OpenBtn" Content="Open…" Click="OnOpen" Margin="0,3,0,3" />
                <Button Content="Open Project…" Click="OnOpenProject" Margin="6,3,0,3" />
                <Button Content="Save Project…" Click="OnSaveProject" Margin="6,3,0,3" />
                <Button x:Name="UndoBtn" Content="↶ Undo" Click="OnUndoPatch" Margin="6,3,0,3" IsEnabled="False" ToolTip="Undo last edit (Ctrl+Z)" />
                <Button x:Name="SavePatchedBtn" Content="Save Patched As…" Click="OnSavePatched" Margin="6,3,0,3" IsEnabled="False" />
                <Border Width="1" Height="18" VerticalAlignment="Center" Background="{StaticResource Outline}" Margin="8,3" />
                <Button Content="Save ASM…" Click="OnSaveAsm" Margin="0,3,0,3" ToolTip="Export the full disassembly listing to a .asm file" />
                <Button Content="Save C…" Click="OnSaveC" Margin="6,3,0,3" ToolTip="Export the decompiled Pseudo-C of all functions to a .c file" />
                <Button Content="Gen Signatures…" Click="OnGenerateSignatures" Margin="6,3,0,3" ToolTip="FLIRT/FID-style: write masked prologue signatures for this binary's named functions to a .sig file. Drop .sig files in the 'signatures' folder beside the app and they auto-name matching functions when you open other binaries." />
                <Border Width="1" Height="18" VerticalAlignment="Center" Background="{StaticResource Outline}" Margin="8,3" />
                <Button x:Name="DbgRunBtn" Style="{StaticResource RunButton}" Content="▶ Run" Click="OnDebugRun" Margin="0,3,0,3" ToolTip="Run / continue (F5)" />
                <Button x:Name="StepIntoBtn" Style="{StaticResource StepButton}" Content="⤓ Into" Click="OnStepInto" Margin="6,3,0,3" IsEnabled="False" ToolTip="Step into (F7)" />
                <Button x:Name="StepOverBtn" Style="{StaticResource StepButton}" Content="⤵ Over" Click="OnStepOver" Margin="6,3,0,3" IsEnabled="False" ToolTip="Step over (F8)" />
                <Button x:Name="StepOutBtn" Style="{StaticResource StepButton}" Content="⤴ Out" Click="OnStepOut" Margin="6,3,0,3" IsEnabled="False" ToolTip="Step out (Shift+F11)" />
                <Button x:Name="RunToRetBtn" Style="{StaticResource StepButton}" Content="⤴▸ To Ret" Click="OnRunToReturn" Margin="6,3,0,3" IsEnabled="False" ToolTip="Continue until the current function returns — stop ON its ret, with calls running at full speed (Ctrl+F9). Falls back to Step Out in unanalyzed code." />
                <Button Style="{StaticResource WarnButton}" Content="⏸ Pause" Click="OnDebugPause" Margin="6,3,0,3" />
                <Button Style="{StaticResource DangerButton}" Content="⏹ Stop" Click="OnDebugStop" Margin="6,3,0,3" />
                <Button x:Name="DetachBtn" Style="{StaticResource DangerButton}" Content="⏏ Detach" Click="OnDebugDetach" Margin="6,3,0,3" IsEnabled="False" ToolTip="Detach the debugger but leave the program running. Restores all breakpoints and hide-layer code patches to the original bytes, clears the debug registers, releases job containment, and stops debugging — the process keeps running. Available only while stopped." />
                <Button x:Name="RestartBtn" Style="{StaticResource RunButton}" Content="⟳ Restart" Click="OnDebugRestart" Margin="6,3,0,3" IsEnabled="False" ToolTip="Terminate the debuggee and launch it again from the start" />
                <ToggleButton x:Name="CoverageToggle" Content="◴ Trace" Click="OnToggleCoverage" Margin="6,3,0,3" IsEnabled="False" ToolTip="Instruction trace from here: starts recording exactly where you're stopped — nothing is planted up front, so there's no whole-image arming. On Continue (F5) it single-steps the loaded module and tints each executed instruction green in the listing; a call into a system DLL runs at full speed and tracing resumes when it returns. Step Into/Over/Out also contribute. Enable while stopped, then Continue or step. Click again to stop tracing (no need to pause). Exact but slower than a free run over long loops." />
                <Button x:Name="ClearCoverageBtn" Content="Clear trace" Click="OnClearCoverage" Margin="6,3,0,3" IsEnabled="False" ToolTip="Clear the execution-trace highlights." />
                <Button Content="Attach…" Click="OnAttach" Margin="6,3,0,3" ToolTip="Attach the debugger to a running process" />
                <Button x:Name="UnpackBtn" Content="Unpack…" Click="OnUnpack" Margin="6,3,0,3" ToolTip="Generic unpacker: run a packed PE under the debugger, stop at the original entry point, dump it, rebuild the IAT and write a clean, re-analyzable EXE." />
                <Button x:Name="DumpProcBtn" Content="Dump Process…" Click="OnDumpProcess" Margin="6,3,0,3" ToolTip="Non-invasive dump: snapshot a process's image to a clean PE WITHOUT debugging it, so an anti-debug protector decrypts itself normally and can't detect us. Attach to a separately-run target, or Launch and watch it from t=0; the Auto watch dumps the moment its image settles, then rebuilds the IAT." />
                <Button x:Name="DevirtBtn" Content="Devirt..." Click="OnDevirt" Margin="6,3,0,3" ToolTip="Experimental VM devirtualizer: analyze a decrypted PE/memory image for a VM dispatcher, handler table and bytecode stream." />
                <Button Content="Exceptions…" Click="OnExceptions" Margin="6,3,0,3" ToolTip="Configure which exceptions break vs pass straight to the program (first/second chance), x64dbg-style. Persisted across sessions and applied live." />
                <CheckBox x:Name="LoaderBreakCheck" Content="Break at loader" Margin="12,3,0,3" ToolTip="When you Run, stop early instead of running free. Native target: stop at the loader breakpoint (before the entry point) so a capture can include TLS callbacks and static DLL DllMains. .NET target: stop at the managed entry point (Main). Set this before Run." />
                <CheckBox x:Name="HideDebuggerCheck" Content="Hide debugger" Margin="12,3,0,3" ToolTip="Anti-anti-debug (ScyllaHide-style): before the entry point, clears the PEB BeingDebugged/NtGlobalFlag/heap-debug flags and hooks ntdll's NtQueryInformationProcess / NtSetInformationThread / NtQuerySystemInformation to report 'not debugged', and defeats the invalid-handle trick. Set this before Run; always on during Unpack." />
                <Border Width="1" Height="18" VerticalAlignment="Center" Background="{StaticResource Outline}" Margin="8,3" />
                <Button x:Name="CaptureBtn" Content="⦿ Capture" Click="OnCaptureAll" Margin="0,3,0,3" IsEnabled="False" ToolTip="FunCap: log each function's arguments + return value on its first call, then stop intercepting it (fast for large programs)" />
                <Button x:Name="CaptureFnBtn" Content="Capture Fn" Click="OnCaptureFunc" Margin="6,3,0,3" IsEnabled="False" ToolTip="Capture every call of the function at the current address" />
                <CheckBox x:Name="OnceCheck" Content="First call only" IsChecked="True" Margin="12,3,0,3" IsEnabled="False" ToolTip="Capture each function once, then let it run at full speed (fast for large programs). Uncheck to capture every call (detailed but much slower)." />
                <CheckBox x:Name="RetCheck" Content="Capture returns" IsChecked="True" Margin="12,3,0,3" IsEnabled="False" ToolTip="Also capture each function's return value (sets a return breakpoint). Uncheck for args-only: about half the events, faster." />
                <CheckBox x:Name="DerefCheck" Content="Dereference args" IsChecked="True" Margin="12,3,0,3" IsEnabled="False" ToolTip="Annotate values with the string/symbol they point to (e.g. rcx → &quot;C:\…&quot;). This per-argument lookup is the main per-hit cost — uncheck to log raw hex values only, which is faster for dense captures." />
                <Border Width="1" Height="18" VerticalAlignment="Center" Background="{StaticResource Outline}" Margin="8,3" />
                <Button x:Name="BackBtn" Content="◀ Back" Click="OnBack" IsEnabled="False" Margin="0,3,0,3" />
                <Button x:Name="FwdBtn" Content="Forward ▶" Click="OnForward" IsEnabled="False" Margin="6,3,0,3" />
                <Border Width="1" Height="18" VerticalAlignment="Center" Background="{StaticResource Outline}" Margin="8,3" />
                <TextBlock Text="Address" VerticalAlignment="Center" Foreground="{StaticResource TextMuted}" Margin="0,3,6,3" />
                <TextBox x:Name="AddrBox" Width="160" Margin="0,3,0,3" FontFamily="Cascadia Mono, Consolas"
                         KeyDown="OnAddrKeyDown" />
                <Button Content="Go" Click="OnGo" Margin="6,3,0,3" />
                <Button x:Name="SectionsBtn" Content="Sections ▾" Click="OnSectionsMenu" Margin="6,3,0,3"
                        ToolTip="Jump to the start of a section (or the PE header) in the linear view — loads a data section into the listing if needed" />
                <TextBlock x:Name="FileInfo" VerticalAlignment="Center" Margin="16,3,0,3"
                           Foreground="{StaticResource TextSecondary}" />
                <Border Width="1" Height="18" VerticalAlignment="Center" Background="{StaticResource Outline}" Margin="8,3" />
                <Button x:Name="HelpBtn" Content="Help ▾" Click="OnHelpMenu" Margin="0,3,0,3" ToolTip="Help (F1)">
                    <Button.ContextMenu>
                        <ContextMenu>
                            <MenuItem Header="Keyboard Shortcuts" InputGestureText="F1" Click="OnHelpShortcuts" />
                            <Separator />
                            <MenuItem Header="About DisasmStudio…" Click="OnHelpAbout" />
                        </ContextMenu>
                    </Button.ContextMenu>
                </Button>
            </WrapPanel>
        </Border>

        <!-- Status bar -->
        <Border DockPanel.Dock="Bottom" Background="{StaticResource Surface}"
                BorderBrush="{StaticResource Outline}" BorderThickness="0,1,0,0" Padding="10,4">
            <Grid>
                <TextBlock x:Name="StatusText" Foreground="{StaticResource TextSecondary}" Text="Open a binary to begin." />
                <ProgressBar x:Name="Progress" Width="160" Height="10" HorizontalAlignment="Right"
                             IsIndeterminate="False" Visibility="Collapsed"
                             Background="{StaticResource Surface2}" Foreground="{StaticResource Accent}" BorderThickness="0" />
            </Grid>
        </Border>

        <!-- Debugger panel (bottom, shown only during a session) -->
        <Border x:Name="DebugDock" DockPanel.Dock="Bottom" Height="240" Visibility="Collapsed"
                Background="{StaticResource Surface}" BorderBrush="{StaticResource Outline}" BorderThickness="0,1,0,0">
            <ctl:DebugPanel x:Name="Debug" />
        </Border>

        <!-- Managed (.NET source-level) debugger panel: call stack + locals, shown during a managed session -->
        <Border x:Name="ManagedDebugDock" DockPanel.Dock="Bottom" Height="200" Visibility="Collapsed"
                Background="{StaticResource Surface}" BorderBrush="{StaticResource Outline}" BorderThickness="0,1,0,0">
            <ctl:ManagedDebugPanel x:Name="ManagedDebug" />
        </Border>

        <!-- Main 3-pane layout -->
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="270" MinWidth="180" />
                <ColumnDefinition Width="5" />
                <ColumnDefinition Width="*" MinWidth="320" />
                <ColumnDefinition Width="5" />
                <ColumnDefinition Width="320" MinWidth="220" />
            </Grid.ColumnDefinitions>

            <!-- Left: functions -->
            <Border Grid.Column="0" Background="{StaticResource Surface}"
                    BorderBrush="{StaticResource Outline}" BorderThickness="0,0,1,0">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Text="FUNCTIONS" Margin="10,8,10,4"
                               Foreground="{StaticResource TextMuted}" FontWeight="SemiBold" FontSize="11" />
                    <TextBox x:Name="FuncFilter" DockPanel.Dock="Top" Margin="8,0,8,6"
                             TextChanged="OnFuncFilter" />
                    <DataGrid x:Name="FuncList" SelectionChanged="OnFuncSelected" MouseDoubleClick="OnFuncActivate"
                              PreviewMouseRightButtonDown="OnFuncRightClick"
                              CanUserAddRows="False" CanUserReorderColumns="False" CanUserResizeRows="False">
                        <DataGrid.ContextMenu>
                            <ContextMenu>
                                <MenuItem Header="Capture this function" Click="OnCaptureSelectedFunc" />
                            </ContextMenu>
                        </DataGrid.ContextMenu>
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="200"
                                                ElementStyle="{StaticResource GridCellText}" />
                            <DataGridTextColumn Header="Address" Binding="{Binding Address, StringFormat='0x{0}'}" Width="104"
                                                ElementStyle="{StaticResource GridCellAccent}" />
                            <DataGridTextColumn Header="Section" Binding="{Binding Section}" Width="*"
                                                ElementStyle="{StaticResource GridCellMuted}" />
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>
            </Border>

            <GridSplitter Grid.Column="1" Width="5" HorizontalAlignment="Stretch" />

            <!-- Center: linear / graph / hex / decompiler -->
            <TabControl Grid.Column="2" x:Name="CenterTabs" Background="{StaticResource Background}"
                        SelectionChanged="OnCenterTabChanged">
                <TabItem Header="Linear">
                    <ctl:LinearDisassemblyView x:Name="Linear" />
                </TabItem>
                <TabItem Header="Graph">
                    <ctl:GraphView x:Name="Graph" />
                </TabItem>
                <TabItem Header="Hex">
                    <ctl:HexView x:Name="Hex" />
                </TabItem>
                <TabItem Header="Decompiler">
                    <ctl:DecompilerView x:Name="Decompiler" />
                </TabItem>
                <!-- Managed (.NET) decompiler — visible only for .NET assemblies. -->
                <TabItem Header="C#" x:Name="ManagedTab" Visibility="Collapsed">
                    <ctl:ManagedDecompilerView x:Name="Managed" />
                </TabItem>
            </TabControl>

            <GridSplitter Grid.Column="3" Width="5" HorizontalAlignment="Stretch" />

            <!-- Right: xrefs / strings / imports / sections -->
            <Border Grid.Column="4" Background="{StaticResource Surface}"
                    BorderBrush="{StaticResource Outline}" BorderThickness="1,0,0,0">
                <TabControl x:Name="SideTabs" Background="{StaticResource Surface}"
                            SelectionChanged="OnSideTabChanged">
                    <TabItem Header="Xrefs">
                        <DockPanel>
                            <TextBlock x:Name="XrefHeader" DockPanel.Dock="Top" Margin="10,8"
                                       Foreground="{StaticResource TextMuted}" FontFamily="Cascadia Mono, Consolas"
                                       Text="Select an address" />
                            <ListBox x:Name="XrefList" MouseDoubleClick="OnXrefActivate"
                                     FontFamily="Cascadia Mono, Consolas" FontSize="12">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{Binding From}" Foreground="{StaticResource Accent}" Width="120" />
                                            <TextBlock Text="{Binding Kind}" Foreground="{StaticResource TextSecondary}" />
                                        </StackPanel>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </DockPanel>
                    </TabItem>
                    <TabItem Header="Strings">
                        <DockPanel>
                            <DockPanel DockPanel.Dock="Top" Margin="8,6,8,2">
                                <Button x:Name="StringRefreshBtn" DockPanel.Dock="Right" Content="⟳ Refresh"
                                        Padding="6,1" Margin="6,3,0,3" Click="OnRefreshStrings"
                                        ToolTip="Rebuild the strings list. While stopped in a live session this re-scans the debuggee's process memory (so decrypted/unpacked strings appear); otherwise it rebuilds from the file's static strings." />
                                <TextBlock x:Name="StringHeader" VerticalAlignment="Center" Margin="2,0,0,0"
                                           Foreground="{StaticResource TextMuted}" FontFamily="Cascadia Mono, Consolas" FontSize="11" Text="" />
                            </DockPanel>
                            <TextBox x:Name="StringFilter" DockPanel.Dock="Top" Margin="8,2,8,6" TextChanged="OnStringFilter" />
                            <ListBox x:Name="StringList" MouseDoubleClick="OnStringActivate"
                                     FontFamily="Cascadia Mono, Consolas" FontSize="12">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{Binding Marker}" Foreground="{StaticResource StringRef}" Width="14"
                                                       ToolTip="Referenced by the current call — recovered from a live argument/register pointer (heap/stack/other module)" />
                                            <TextBlock Text="{Binding Address}" Foreground="{StaticResource Accent}" Width="92" />
                                            <TextBlock Text="{Binding Text}" Foreground="{StaticResource TextPrimary}"
                                                       TextTrimming="CharacterEllipsis" />
                                        </StackPanel>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </DockPanel>
                    </TabItem>
                    <TabItem Header="Imports">
                        <ListBox x:Name="ImportList" MouseDoubleClick="OnImportActivate"
                                 FontFamily="Cascadia Mono, Consolas" FontSize="12">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{Binding Name}" Foreground="{StaticResource TextPrimary}" Width="170"
                                                   TextTrimming="CharacterEllipsis" />
                                        <TextBlock Text="{Binding Module}" Foreground="{StaticResource TextMuted}" />
                                    </StackPanel>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </TabItem>
                    <TabItem Header="Exports">
                        <DockPanel>
                            <TextBox x:Name="ExportFilter" DockPanel.Dock="Top" Margin="8,8,8,6" TextChanged="OnExportFilter" />
                            <ListBox x:Name="ExportList" MouseDoubleClick="OnExportActivate"
                                     FontFamily="Cascadia Mono, Consolas" FontSize="12">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{Binding Address}" Foreground="{StaticResource Accent}" Width="92" />
                                            <TextBlock Text="{Binding Name}" Foreground="{StaticResource TextPrimary}"
                                                       TextTrimming="CharacterEllipsis" />
                                        </StackPanel>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </DockPanel>
                    </TabItem>
                    <TabItem Header="Breakpoints">
                        <DockPanel>
                            <TextBlock DockPanel.Dock="Top" Margin="10,8,10,4" TextWrapping="Wrap"
                                       Foreground="{StaticResource TextMuted}" FontSize="11"
                                       Text="Breakpoints set with F2 or the gutter (before Run or during a session); right-click an instruction for a hardware breakpoint or to add a condition / hit-count. Double-click to jump; right-click here to edit or remove (Delete removes)." />
                            <ListBox x:Name="BreakpointList" MouseDoubleClick="OnBreakpointActivate"
                                     KeyDown="OnBreakpointListKey"
                                     FontFamily="Cascadia Mono, Consolas" FontSize="12">
                                <ListBox.ContextMenu>
                                    <ContextMenu>
                                        <MenuItem Header="Jump to breakpoint" Click="OnBreakpointJump" />
                                        <MenuItem Header="Edit breakpoint…" Click="OnBreakpointEditMenu" />
                                        <MenuItem Header="Remove breakpoint" Click="OnBreakpointRemove" />
                                    </ContextMenu>
                                </ListBox.ContextMenu>
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{Binding Address}" Foreground="{StaticResource Accent}" Width="120" />
                                            <TextBlock Text="{Binding Label}" Foreground="{StaticResource TextPrimary}"
                                                       TextTrimming="CharacterEllipsis" />
                                        </StackPanel>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </DockPanel>
                    </TabItem>
                    <TabItem Header="Bookmarks">
                        <DockPanel>
                            <TextBlock DockPanel.Dock="Top" Margin="10,8,10,4" TextWrapping="Wrap"
                                       Foreground="{StaticResource TextMuted}" FontSize="11"
                                       Text="Bookmark any address from the listing / graph / decompiler / hex (right-click → Toggle bookmark). Rename symbols (N) and add comments (;) the same way. Double-click a bookmark to jump; Delete or right-click → Remove to clear it. All of this is saved in the .dsproj." />
                            <ListBox x:Name="BookmarkList" MouseDoubleClick="OnBookmarkActivate"
                                     KeyDown="OnBookmarkListKey"
                                     FontFamily="Cascadia Mono, Consolas" FontSize="12">
                                <ListBox.ContextMenu>
                                    <ContextMenu>
                                        <MenuItem Header="Jump to bookmark" Click="OnBookmarkJump" />
                                        <MenuItem Header="Remove bookmark" Click="OnBookmarkRemove" />
                                    </ContextMenu>
                                </ListBox.ContextMenu>
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{Binding Address}" Foreground="{StaticResource Accent}" Width="120" />
                                            <TextBlock Text="{Binding Label}" Foreground="{StaticResource TextPrimary}"
                                                       TextTrimming="CharacterEllipsis" />
                                        </StackPanel>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </DockPanel>
                    </TabItem>
                    <TabItem Header="Call Graph">
                        <ctl:CallGraphView x:Name="CallGraphPanel" />
                    </TabItem>
                    <TabItem Header="Sections">
                        <DockPanel>
                            <TextBlock DockPanel.Dock="Top" Margin="10,8,10,4" TextWrapping="Wrap"
                                       Foreground="{StaticResource TextMuted}" FontSize="11"
                                       Text="Double-click a row to jump (data → Hex). Right-click → 'Show in listing'. Tick to show/hide a section in the listing. In the listing, click the [+]/[−] in the gutter to collapse a section." />
                            <ListBox x:Name="SectionList" MouseDoubleClick="OnSectionActivate"
                                     PreviewMouseRightButtonDown="OnSectionRightClick"
                                     FontFamily="Cascadia Mono, Consolas" FontSize="12">
                                <ListBox.ContextMenu>
                                    <ContextMenu>
                                        <MenuItem Header="Show in listing + jump" Click="OnSectionJumpFold" />
                                        <MenuItem Header="Jump (data opens in Hex)" Click="OnSectionJumpHex" />
                                    </ContextMenu>
                                </ListBox.ContextMenu>
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal">
                                            <CheckBox IsChecked="{Binding Loaded, Mode=OneWay}" IsEnabled="{Binding CanToggle}"
                                                      Click="OnSectionLoadToggle" VerticalAlignment="Center" Margin="0,0,6,0"
                                                      ToolTip="Show this section/header in the linear listing as data (re-analyses)" />
                                            <TextBlock Text="{Binding Name}" Foreground="{StaticResource TextPrimary}" Width="72" VerticalAlignment="Center" />
                                            <TextBlock Text="{Binding Range}" Foreground="{StaticResource TextSecondary}" Width="150" VerticalAlignment="Center" />
                                            <TextBlock Text="{Binding Perms}" Foreground="{StaticResource TextMuted}" VerticalAlignment="Center" />
                                        </StackPanel>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </DockPanel>
                    </TabItem>
                    <TabItem Header="Resources">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="2*" MinHeight="80" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="3*" MinHeight="120" />
                            </Grid.RowDefinitions>
                            <TreeView x:Name="ResTree" Grid.Row="0"
                                      SelectedItemChanged="OnResourceSelected" MouseDoubleClick="OnResourceActivate"
                                      FontFamily="Cascadia Mono, Consolas" FontSize="12">
                                <TreeView.ItemTemplate>
                                    <HierarchicalDataTemplate ItemsSource="{Binding Children}">
                                        <TextBlock Text="{Binding Display}" Foreground="{StaticResource TextPrimary}" />
                                    </HierarchicalDataTemplate>
                                </TreeView.ItemTemplate>
                            </TreeView>
                            <GridSplitter Grid.Row="1" Height="5" HorizontalAlignment="Stretch"
                                          Background="{StaticResource Outline}" />
                            <DockPanel Grid.Row="2">
                                <Grid DockPanel.Dock="Top" Margin="8,6">
                                    <TextBlock x:Name="ResHeader" Foreground="{StaticResource TextSecondary}" FontSize="11.5"
                                               Text="Select a resource" VerticalAlignment="Center"
                                               TextTrimming="CharacterEllipsis" Margin="0,0,110,0" />
                                    <Button x:Name="ResSaveBtn" Content="Save resource…" Click="OnSaveResource"
                                            HorizontalAlignment="Right" IsEnabled="False" />
                                </Grid>
                                <ContentControl x:Name="ResPreviewHost" />
                            </DockPanel>
                        </Grid>
                    </TabItem>
                    <!-- .NET: managed assembly metadata + extractable embedded resources/assemblies. -->
                    <TabItem Header=".NET" x:Name="DotNetTab" Visibility="Collapsed">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" MinHeight="120" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <TextBlock x:Name="NetInfo" Grid.Row="0" Margin="8,6" TextWrapping="Wrap"
                                       Foreground="{StaticResource TextSecondary}" FontSize="11.5" />
                            <ListBox x:Name="NetResList" Grid.Row="1" SelectionChanged="OnNetResourceSelected"
                                     MouseDoubleClick="OnNetResourceActivate"
                                     FontFamily="Cascadia Mono, Consolas" FontSize="11.5"
                                     Background="{StaticResource Surface}" BorderThickness="0">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal" Margin="2,1">
                                            <TextBlock Text="{Binding Kind}" Foreground="{StaticResource Accent}" Width="130" />
                                            <TextBlock Text="{Binding Size}" Foreground="{StaticResource TextMuted}" Width="90"
                                                       TextAlignment="Right" Margin="0,0,10,0" />
                                            <TextBlock Text="{Binding Name}" Foreground="{StaticResource TextPrimary}"
                                                       TextTrimming="CharacterEllipsis" />
                                        </StackPanel>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                            <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="8,6" HorizontalAlignment="Right">
                                <Button x:Name="NetSaveBtn" Content="Save selected…" Click="OnNetSaveResource" IsEnabled="False" Margin="0,0,6,0" />
                                <Button x:Name="NetExtractAllBtn" Content="Extract all…" Click="OnNetExtractAll" IsEnabled="False" />
                            </StackPanel>
                        </Grid>
                    </TabItem>
                    <TabItem Header="Search">
                        <DockPanel>
                            <StackPanel DockPanel.Dock="Top" Margin="8,6,8,4">
                                <TextBlock Text="Search functions · strings · imports · exports"
                                           Foreground="{StaticResource TextMuted}" FontSize="11" Margin="2,0,0,4" />
                                <TextBox x:Name="SearchBox" TextChanged="OnSearchFilter"
                                         ToolTip="Type text or a hex address. Click a result to list every reference to it below; double-click a result to jump to its definition, or a reference to jump to that call site." />
                                <TextBlock x:Name="SearchHeader" Margin="2,4,0,0"
                                           Foreground="{StaticResource TextMuted}" FontFamily="Cascadia Mono, Consolas" FontSize="11" Text="" />
                            </StackPanel>
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="2*" MinHeight="80" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="3*" MinHeight="100" />
                                </Grid.RowDefinitions>
                                <ListBox x:Name="SearchResults" Grid.Row="0"
                                         SelectionChanged="OnSearchResultSelected" MouseDoubleClick="OnSearchResultActivate"
                                         FontFamily="Cascadia Mono, Consolas" FontSize="12">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="{Binding Kind}" Foreground="{StaticResource TextMuted}" Width="34" />
                                                <TextBlock Text="{Binding Address}" Foreground="{StaticResource Accent}" Width="92" />
                                                <TextBlock Text="{Binding Text}" Foreground="{StaticResource TextPrimary}"
                                                           TextTrimming="CharacterEllipsis" />
                                            </StackPanel>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                                <GridSplitter Grid.Row="1" Height="5" HorizontalAlignment="Stretch"
                                              Background="{StaticResource Outline}" />
                                <TextBlock x:Name="SearchRefHeader" Grid.Row="2" Margin="10,6,10,4"
                                           Foreground="{StaticResource TextMuted}" FontFamily="Cascadia Mono, Consolas" FontSize="11"
                                           Text="Select a result to list references" TextTrimming="CharacterEllipsis" />
                                <ListBox x:Name="SearchRefs" Grid.Row="3" MouseDoubleClick="OnSearchRefActivate"
                                         FontFamily="Cascadia Mono, Consolas" FontSize="12">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="{Binding From}" Foreground="{StaticResource Accent}" Width="92" />
                                                <TextBlock Text="{Binding Kind}" Foreground="{StaticResource TextSecondary}" Width="52" />
                                                <TextBlock Text="{Binding Context}" Foreground="{StaticResource TextMuted}"
                                                           TextTrimming="CharacterEllipsis" />
                                            </StackPanel>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </Grid>
                        </DockPanel>
                    </TabItem>
                </TabControl>
            </Border>
        </Grid>
    </DockPanel>
</Window>
