<Window x:Class="DisasmStudio.Wpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ctl="clr-namespace:DisasmStudio.Wpf.Controls"
        Title="DisasmStudio" Height="820" Width="1320"
        FontFamily="Segoe UI" FontSize="12.5">
    <DockPanel>
        <!-- Toolbar -->
        <Border DockPanel.Dock="Top" Background="{StaticResource Surface}"
                BorderBrush="{StaticResource Outline}" BorderThickness="0,0,0,1" Padding="8,6">
            <!-- WrapPanel so a narrow window flows buttons onto another row instead of clipping them. -->
            <WrapPanel>
                <Button x:Name="OpenBtn" Content="Open…" Click="OnOpen" />
                <Button Content="Open Project…" Click="OnOpenProject" Margin="6,0,0,0" />
                <Button Content="Save Project…" Click="OnSaveProject" Margin="6,0,0,0" />
                <Button x:Name="UndoBtn" Content="↶ Undo" Click="OnUndoPatch" Margin="6,0,0,0" IsEnabled="False" ToolTip="Undo last edit (Ctrl+Z)" />
                <Button x:Name="SavePatchedBtn" Content="Save Patched As…" Click="OnSavePatched" Margin="6,0,0,0" IsEnabled="False" />
                <Border Width="1" Height="18" VerticalAlignment="Center" Background="{StaticResource Outline}" Margin="8,3" />
                <Button Content="Save ASM…" Click="OnSaveAsm" ToolTip="Export the full disassembly listing to a .asm file" />
                <Button Content="Save C…" Click="OnSaveC" Margin="6,0,0,0" ToolTip="Export the decompiled Pseudo-C of all functions to a .c file" />
                <Border Width="1" Height="18" VerticalAlignment="Center" Background="{StaticResource Outline}" Margin="8,3" />
                <Button x:Name="DbgRunBtn" Content="▶ Run" Click="OnDebugRun" ToolTip="Run / continue (F5)" />
                <Button x:Name="StepIntoBtn" Content="⤓ Into" Click="OnStepInto" Margin="6,0,0,0" IsEnabled="False" ToolTip="Step into (F7)" />
                <Button x:Name="StepOverBtn" Content="⤵ Over" Click="OnStepOver" Margin="6,0,0,0" IsEnabled="False" ToolTip="Step over (F8)" />
                <Button x:Name="StepOutBtn" Content="⤴ Out" Click="OnStepOut" Margin="6,0,0,0" IsEnabled="False" ToolTip="Step out (Shift+F11)" />
                <Button Content="⏸ Pause" Click="OnDebugPause" Margin="6,0,0,0" />
                <Button Content="⏹ Stop" Click="OnDebugStop" Margin="6,0,0,0" />
                <Button x:Name="RestartBtn" Content="⟳ Restart" Click="OnDebugRestart" Margin="6,0,0,0" IsEnabled="False" ToolTip="Terminate the debuggee and launch it again from the start" />
                <Button Content="Attach…" Click="OnAttach" Margin="6,0,0,0" ToolTip="Attach the debugger to a running process" />
                <Border Width="1" Height="18" VerticalAlignment="Center" Background="{StaticResource Outline}" Margin="8,3" />
                <Button x:Name="CaptureBtn" Content="⦿ Capture" Click="OnCaptureAll" IsEnabled="False" ToolTip="FunCap: log each function's arguments + return value on its first call, then stop intercepting it (fast for large programs)" />
                <Button x:Name="CaptureFnBtn" Content="Capture Fn" Click="OnCaptureFunc" Margin="6,0,0,0" IsEnabled="False" ToolTip="Capture every call of the function at the current address" />
                <CheckBox x:Name="OnceCheck" Content="First call only" IsChecked="True" Margin="12,0,0,0" IsEnabled="False" ToolTip="Capture each function once, then let it run at full speed (fast for large programs). Uncheck to capture every call (detailed but much slower)." />
                <CheckBox x:Name="RetCheck" Content="Capture returns" IsChecked="True" Margin="12,0,0,0" IsEnabled="False" ToolTip="Also capture each function's return value (sets a return breakpoint). Uncheck for args-only: about half the events, faster." />
                <CheckBox x:Name="DerefCheck" Content="Dereference args" IsChecked="True" Margin="12,0,0,0" IsEnabled="False" ToolTip="Annotate values with the string/symbol they point to (e.g. rcx → &quot;C:\…&quot;). This per-argument lookup is the main per-hit cost — uncheck to log raw hex values only, which is faster for dense captures." />
                <Border Width="1" Height="18" VerticalAlignment="Center" Background="{StaticResource Outline}" Margin="8,3" />
                <Button x:Name="BackBtn" Content="◀ Back" Click="OnBack" IsEnabled="False" />
                <Button x:Name="FwdBtn" Content="Forward ▶" Click="OnForward" IsEnabled="False" Margin="6,0,0,0" />
                <Border Width="1" Height="18" VerticalAlignment="Center" Background="{StaticResource Outline}" Margin="8,3" />
                <TextBlock Text="Address" VerticalAlignment="Center" Foreground="{StaticResource TextMuted}" Margin="0,0,6,0" />
                <TextBox x:Name="AddrBox" Width="160" FontFamily="Cascadia Mono, Consolas"
                         KeyDown="OnAddrKeyDown" />
                <Button Content="Go" Click="OnGo" Margin="6,0,0,0" />
                <TextBlock x:Name="FileInfo" VerticalAlignment="Center" Margin="16,0,0,0"
                           Foreground="{StaticResource TextSecondary}" />
            </WrapPanel>
        </Border>

        <!-- Status bar -->
        <Border DockPanel.Dock="Bottom" Background="{StaticResource Surface}"
                BorderBrush="{StaticResource Outline}" BorderThickness="0,1,0,0" Padding="10,4">
            <Grid>
                <TextBlock x:Name="StatusText" Foreground="{StaticResource TextSecondary}" Text="Open a binary to begin." />
                <ProgressBar x:Name="Progress" Width="160" Height="10" HorizontalAlignment="Right"
                             IsIndeterminate="False" Visibility="Collapsed"
                             Background="{StaticResource Surface2}" Foreground="{StaticResource Accent}" BorderThickness="0" />
            </Grid>
        </Border>

        <!-- Debugger panel (bottom, shown only during a session) -->
        <Border x:Name="DebugDock" DockPanel.Dock="Bottom" Height="240" Visibility="Collapsed"
                Background="{StaticResource Surface}" BorderBrush="{StaticResource Outline}" BorderThickness="0,1,0,0">
            <ctl:DebugPanel x:Name="Debug" />
        </Border>

        <!-- Main 3-pane layout -->
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="270" MinWidth="180" />
                <ColumnDefinition Width="5" />
                <ColumnDefinition Width="*" MinWidth="320" />
                <ColumnDefinition Width="5" />
                <ColumnDefinition Width="320" MinWidth="220" />
            </Grid.ColumnDefinitions>

            <!-- Left: functions -->
            <Border Grid.Column="0" Background="{StaticResource Surface}"
                    BorderBrush="{StaticResource Outline}" BorderThickness="0,0,1,0">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Text="FUNCTIONS" Margin="10,8,10,4"
                               Foreground="{StaticResource TextMuted}" FontWeight="SemiBold" FontSize="11" />
                    <TextBox x:Name="FuncFilter" DockPanel.Dock="Top" Margin="8,0,8,6"
                             TextChanged="OnFuncFilter" />
                    <DataGrid x:Name="FuncList" SelectionChanged="OnFuncSelected" MouseDoubleClick="OnFuncActivate"
                              CanUserAddRows="False" CanUserReorderColumns="False" CanUserResizeRows="False">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="200"
                                                ElementStyle="{StaticResource GridCellText}" />
                            <DataGridTextColumn Header="Address" Binding="{Binding Address, StringFormat='0x{0}'}" Width="104"
                                                ElementStyle="{StaticResource GridCellAccent}" />
                            <DataGridTextColumn Header="Section" Binding="{Binding Section}" Width="*"
                                                ElementStyle="{StaticResource GridCellMuted}" />
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>
            </Border>

            <GridSplitter Grid.Column="1" Width="5" HorizontalAlignment="Stretch" />

            <!-- Center: linear / graph / hex / decompiler -->
            <TabControl Grid.Column="2" x:Name="CenterTabs" Background="{StaticResource Background}"
                        SelectionChanged="OnCenterTabChanged">
                <TabItem Header="Linear">
                    <ctl:LinearDisassemblyView x:Name="Linear" />
                </TabItem>
                <TabItem Header="Graph">
                    <ctl:GraphView x:Name="Graph" />
                </TabItem>
                <TabItem Header="Hex">
                    <ctl:HexView x:Name="Hex" />
                </TabItem>
                <TabItem Header="Decompiler">
                    <ctl:DecompilerView x:Name="Decompiler" />
                </TabItem>
            </TabControl>

            <GridSplitter Grid.Column="3" Width="5" HorizontalAlignment="Stretch" />

            <!-- Right: xrefs / strings / imports / sections -->
            <Border Grid.Column="4" Background="{StaticResource Surface}"
                    BorderBrush="{StaticResource Outline}" BorderThickness="1,0,0,0">
                <TabControl x:Name="SideTabs" Background="{StaticResource Surface}">
                    <TabItem Header="Xrefs">
                        <DockPanel>
                            <TextBlock x:Name="XrefHeader" DockPanel.Dock="Top" Margin="10,8"
                                       Foreground="{StaticResource TextMuted}" FontFamily="Cascadia Mono, Consolas"
                                       Text="Select an address" />
                            <ListBox x:Name="XrefList" MouseDoubleClick="OnXrefActivate"
                                     FontFamily="Cascadia Mono, Consolas" FontSize="12">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{Binding From}" Foreground="{StaticResource Accent}" Width="120" />
                                            <TextBlock Text="{Binding Kind}" Foreground="{StaticResource TextSecondary}" />
                                        </StackPanel>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </DockPanel>
                    </TabItem>
                    <TabItem Header="Strings">
                        <DockPanel>
                            <TextBox x:Name="StringFilter" DockPanel.Dock="Top" Margin="8,8,8,6" TextChanged="OnStringFilter" />
                            <ListBox x:Name="StringList" MouseDoubleClick="OnStringActivate"
                                     FontFamily="Cascadia Mono, Consolas" FontSize="12">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{Binding Address}" Foreground="{StaticResource Accent}" Width="92" />
                                            <TextBlock Text="{Binding Text}" Foreground="{StaticResource TextPrimary}"
                                                       TextTrimming="CharacterEllipsis" />
                                        </StackPanel>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </DockPanel>
                    </TabItem>
                    <TabItem Header="Imports">
                        <ListBox x:Name="ImportList" MouseDoubleClick="OnImportActivate"
                                 FontFamily="Cascadia Mono, Consolas" FontSize="12">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{Binding Name}" Foreground="{StaticResource TextPrimary}" Width="170"
                                                   TextTrimming="CharacterEllipsis" />
                                        <TextBlock Text="{Binding Module}" Foreground="{StaticResource TextMuted}" />
                                    </StackPanel>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </TabItem>
                    <TabItem Header="Exports">
                        <DockPanel>
                            <TextBox x:Name="ExportFilter" DockPanel.Dock="Top" Margin="8,8,8,6" TextChanged="OnExportFilter" />
                            <ListBox x:Name="ExportList" MouseDoubleClick="OnExportActivate"
                                     FontFamily="Cascadia Mono, Consolas" FontSize="12">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{Binding Address}" Foreground="{StaticResource Accent}" Width="92" />
                                            <TextBlock Text="{Binding Name}" Foreground="{StaticResource TextPrimary}"
                                                       TextTrimming="CharacterEllipsis" />
                                        </StackPanel>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </DockPanel>
                    </TabItem>
                    <TabItem Header="Sections">
                        <ListBox x:Name="SectionList" MouseDoubleClick="OnSectionActivate"
                                 FontFamily="Cascadia Mono, Consolas" FontSize="12">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{Binding Name}" Foreground="{StaticResource TextPrimary}" Width="80" />
                                        <TextBlock Text="{Binding Range}" Foreground="{StaticResource TextSecondary}" Width="170" />
                                        <TextBlock Text="{Binding Perms}" Foreground="{StaticResource TextMuted}" />
                                    </StackPanel>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </TabItem>
                </TabControl>
            </Border>
        </Grid>
    </DockPanel>
</Window>
